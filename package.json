{
  "name": "WalksCloudOfficialWebsite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run preview",
    "build": "bun run build:ssg",
    "build:ssg": "vite-ssg build && node scripts/generate-meta.js && node scripts/format-dist.js",
    "build:ssg:watch": "chokidar \"src/**/*\" \"public/**/*\" \"config/**/*\" \"scripts/**/*\" --initial -c \"bun run build:ssg\"",
    "preview:nginx:reload": "chokidar \"deploy/*.conf\" --initial -c \"zsh -lic 'docker compose -f docker-compose.preview.yml up --force-recreate || true'\"",
    "preview": "concurrently -k \"bun run build:ssg:watch\" \"bun run preview:nginx:reload\" \"zsh -lic 'docker compose -f docker-compose.preview.yml up --force-recreate'\""
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@nuxt/ui": "^4.6.1",
    "@tailwindcss/vite": "^4.2.2",
    "@unhead/vue": "^3.0.3",
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "globby": "^16.2.0",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "git-rev-sync": "^3.0.2",
    "luxon": "^3.7.2",
    "prettier": "^3.8.2",
    "sass-embedded": "^1.99.0",
    "vite": "^8.0.3",
    "yaml": "^2.8.3"
  }
}
