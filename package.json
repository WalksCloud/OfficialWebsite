    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "globby": "^16.2.0",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "vite-ssg": "^28.3.0",
