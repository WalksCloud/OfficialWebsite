{
  "name": "walkscloud-official-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run preview",
    "build": "./scripts/build.sh",
    "build:ssg": "bun run build -- build",
    "build:ssg:watch": "bun run build -- watch",
    "preview:nginx:reload": "bun run preview -- reload || test $? -eq 130",
